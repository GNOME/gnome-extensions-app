msgstr "Іздеуді іске қосу/сөндіру"

#: data/ui/shortcuts-dialog.ui:28
msgctxt "shortcut window"
msgid "Show Shortcuts"
msgstr "Жарлықтарды көрсету"

#: data/ui/shortcuts-dialog.ui:34
msgctxt "shortcut window"
msgid "Quit"
msgstr "Шығу"
