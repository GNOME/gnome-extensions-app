#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:13
#: data/org.gnome.Extensions.desktop.in.in:3 data/ui/extensions-window.ui:67
msgid "Extensions"
msgstr "Phần mở rộng"

#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:14
msgid "Manage your GNOME Extensions"
msgstr "Quản lý các phần mở rộng GNOME của bạn"

#. developer_name tag deprecated with Appstream 1.0
#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:28
#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:30
msgid "The GNOME Project"
msgstr "Dự án GNOME"

#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:60
msgid ""
"GNOME Extensions handles updating extensions, configuring extension "
"preferences and removing or disabling unwanted extensions."
msgstr ""
"Phần mở rộng GNOME xử lý việc cập nhật tiện ích mở rộng, cấu hình tùy chọn "
"tiện ích mở rộng và xóa hoặc vô hiệu hóa các tiện ích mở rộng không mong "
"muốn."

#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:73
msgid "Main Window"
msgstr "Cửa sổ chính"

#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:77
msgid "Available Updates"
msgstr "Các Bản cập nhật Đang Có"

#: data/metainfo/org.gnome.Extensions.metainfo.xml.in:81
msgid "Search View"
msgstr "Xem Tìm kiếm"

#: data/org.gnome.Extensions.desktop.in.in:6
msgid "Configure GNOME Shell Extensions"
msgstr "Cấu hình Phần mở rộng Hệ vỏ GNOME"

#: js/extensionManager.js:241
#, javascript-format
msgid ""
"The installed version of this extension (%s) is incompatible with the "
"current version of GNOME (%s). The extension has been disabled."
msgstr ""
"Phiên bản đã cài đặt (%s) của phần mở rộng này không tương thích với phiên "
"bản GNOME hiện tại (%s). Đã vô hiệu hóa."

#: js/extensionManager.js:242
#, javascript-format
msgid ""
"The installed version of this extension is incompatible with the current "
"version of GNOME (%s). The extension has been disabled."
msgstr ""
"Phiên bản đã cài đặt của phần mở rộng này không tương thích với phiên bản "
"GNOME hiện tại (%s). Đã vô hiệu hóa."

#: js/extensionManager.js:246
msgid ""
"An error has occurred in this extension. This could cause issues elsewhere "
"in the system. It is recommended to turn the extension off until the error "
"is resolved."
msgstr ""
"Đã xảy ra lỗi từ phần mở rộng này. Việc này có thể gây ra các vấn đề ở nơi "
"khác trong hệ thống. Nên vô hiệu hóa phần mở rộng này đến khi lỗi đã được "
"giải quyết."

#. translators: Details for an extension error
#: js/extensionManager.js:252
msgid "Error details:"
msgstr "Chi tiết lỗi:"

#: js/extensionRow.js:86
#, javascript-format
msgid "Version %s"
msgstr "Phiên bản %s"

#: js/extensionsWindow.js:112
#, javascript-format
msgid "Remove “%s”?"
msgstr "Xóa “%s”?"

#: js/extensionsWindow.js:113
msgid ""
"If you remove the extension, you need to return to download it if you want "
"to enable it again"
msgstr ""
"Nếu bạn gỡ bỏ phần mở rộng này, bạn sẽ cần phải tải lại nó nếu muốn dùng lại"

#: js/extensionsWindow.js:116
msgid "_Cancel"
msgstr "Thôi"

#: js/extensionsWindow.js:117
msgid "_Remove"
msgstr "Xóa bỏ"

#: js/extensionsWindow.js:157
msgid "translator-credits"
msgstr "Nhóm Việt hóa GNOME <gnome-vi-list@gnome.org>"

#: js/extensionsWindow.js:202
#, javascript-format
msgid "%d extension will be updated on next login."
msgid_plural "%d extensions will be updated on next login."
msgstr[0] "%d phần mở rộng sẽ được cập nhật vào lần đăng nhập tới."

#: data/ui/extension-row.ui:20
msgid "Error Details"
msgstr "Chi tiết Lỗi"

#: data/ui/extension-row.ui:58
msgid "Updates Details"
msgstr "Chi tiết Bản cập nhật"

#: data/ui/extension-row.ui:75
msgid ""
"A new version of this extension is ready and will be loaded on next login."
msgstr ""
"Một bản cập nhật của phần mở rộng này sẽ được áp dụng vào lần đăng nhập tới."

#: data/ui/extension-row.ui:107
msgid "Extension Details"
msgstr "Chi tiết Phần mở rộng"

#: data/ui/extension-row.ui:195
msgid "_Website"
msgstr "Trang thông tin điện tử"

#: data/ui/extension-row.ui:222
msgid "_Settings"
msgstr "Cài đặt"

#: data/ui/extension-row.ui:249
msgid "_Remove…"
msgstr "Gỡ bỏ…"

#: data/ui/extensions-window.ui:16
msgid "Keyboard Shortcuts"
msgstr "Phím tắt"

#: data/ui/extensions-window.ui:20
msgid "About Extensions"
msgstr "Giới thiệu Phần mở rộng"

#: data/ui/extensions-window.ui:74
msgid "Main Menu"
msgstr "Trình đơn Chính"

#: data/ui/extensions-window.ui:83
msgid "Search"
msgstr "Tìm"

#: data/ui/extensions-window.ui:116
msgid "Search extensions"
msgstr "Tìm kiếm phần mở rộng"

#: data/ui/extensions-window.ui:133
msgid "_Log Out…"
msgstr "Đăng xuất…"

#: data/ui/extensions-window.ui:141
msgid "_Extensions"
msgstr "Phần mở rộng"

#: data/ui/extensions-window.ui:146
msgid "More Information"
msgstr "Các Thông tin thêm"

#: data/ui/extensions-window.ui:158
msgid ""
"Extensions can cause performance and stability issues. It is recommended to "
"disable all extensions if you experience problems with your system."
msgstr ""
"Phần mở rộng có thể là nguyên nhân dẫn đến các vấn đề về hiệu năng và ổn "
"định. Tắt các phần mở rộng nếu hệ thống của bạn gặp trục trặc."

#: data/ui/extensions-window.ui:185
msgid "User Extensions"
msgstr "Phần mở rộng Của Người dùng"

#: data/ui/extensions-window.ui:194
msgid "System Extensions"
msgstr "Phần mở rộng Hệ thống"

#: data/ui/extensions-window.ui:213
msgid "Search Results"
msgstr "Kết quả Tìm kiếm"

#: data/ui/extensions-window.ui:227
msgid "No Results Found"
msgstr "Không Tìm thấy Kết quả"

#: data/ui/extensions-window.ui:228
msgid "Try a different search"
msgstr "Hãy thử tìm kiếm khác"

#: data/ui/extensions-window.ui:239
msgid "No Installed Extensions"
msgstr "Không có Phần mở rộng nào Được cài đặt"

#: data/ui/extensions-window.ui:240
msgid ""
"To find and add extensions, visit <a href=\"https://"
"extensions.gnome.org\">extensions.gnome.org</a>."
msgstr ""
"Để tìm và thêm các thành phần mở rộng, truy cập <a href=\"https://"
"extensions.gnome.org\">extensions.gnome.org</a>."

#: data/ui/extensions-window.ui:250
msgid "Something’s gone wrong"
msgstr "Đã có sự cố xảy ra"

#: data/ui/extensions-window.ui:251
msgid ""
"We’re very sorry, but it was not possible to get the list of installed "
"extensions. Make sure you are logged into GNOME and try again."
msgstr ""
"Chúng tôi rất tiếc, nhưng không thể lấy được danh sách các tiện ích mở rộng "
"đã cài đặt. Hãy chắc chắn rằng bạn đã đăng nhập vào GNOME và thử lại."

